LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Provider egress routing.
# direct: connect from the LiveKit worker directly.
# proxy: connect through the VPS Squid HTTP CONNECT proxy in EGRESS_PROXY_URL.
# Do not set global HTTPS_PROXY for the agent; use per-provider egress instead.
EGRESS_PROXY_URL=http://66.248.207.203:15182
EGRESS_DEFAULT=direct
# Defaults based on latency/geoblock tests from the local robot:
ELEVENLABS_EGRESS=proxy
GEMINI_EGRESS=proxy
GOOGLE_TTS_EGRESS=proxy
VERTEX_TTS_EGRESS=proxy
GOOGLE_STT_EGRESS=proxy
TBANK_VOICEKIT_EGRESS=direct
XAI_EGRESS=direct
DEEPGRAM_EGRESS=direct
MINIMAX_TTS_EGRESS=direct
COSYVOICE_TTS_EGRESS=direct
LIVEKIT_INFERENCE_EGRESS=proxy

# TTS provider: elevenlabs | google | vertex | minimax | cosyvoice | tbank
TTS_PROVIDER=elevenlabs
ELEVENLABS_VOICE_ID=wF58OrxELqJ5nFJxXiva
ELEVENLABS_MODEL=eleven_flash_v2_5
# Custom eleven_v3 HTTP streaming path.
# Turn on by setting:
# ELEVENLABS_MODEL=eleven_v3
# ELEVENLABS_V3_USE_STREAM_INPUT=true
ELEVENLABS_V3_USE_STREAM_INPUT=true
ELEVENLABS_V3_OUTPUT_FORMAT=mp3_22050_32
ELEVENLABS_V3_ENABLE_LOGGING=true
ELEVENLABS_V3_APPLY_TEXT_NORMALIZATION=auto
ELEVENLABS_V3_LANGUAGE=
# Not supported by eleven_v3 (keep empty).
ELEVENLABS_V3_OPTIMIZE_STREAMING_LATENCY=
ELEVENLABS_V3_REQUEST_TIMEOUT_SEC=30.0
# Sentence buffering for HTTP stream segments.
ELEVENLABS_V3_MIN_SENTENCE_LEN=6
ELEVENLABS_V3_STREAM_CONTEXT_LEN=2

# Optional ElevenLabs voice settings (stability + similarity must be set together).
ELEVENLABS_VOICE_STABILITY=
ELEVENLABS_VOICE_SIMILARITY_BOOST=
ELEVENLABS_VOICE_STYLE=
ELEVENLABS_VOICE_SPEED=
ELEVENLABS_VOICE_USE_SPEAKER_BOOST=

# T-Bank VoiceKit shared auth.
# Used by TTS_PROVIDER=tbank and STT_PROVIDER=tbank.
TBANK_VOICEKIT_API_KEY=
TBANK_VOICEKIT_SECRET_KEY=
TBANK_VOICEKIT_ENDPOINT=api.tinkoff.ai:443
# Optional TLS/SNI override for IP endpoints, e.g. api.tinkoff.ai.
TBANK_VOICEKIT_AUTHORITY=

# T-Bank VoiceKit TTS (gRPC StreamingSynthesize response stream)
TTS_TBANK_VOICE_NAME=anna
TTS_TBANK_PITCH=0.8
TTS_TBANK_SPEAKING_RATE=1.0
TTS_TBANK_FORMAT=linear16
TTS_TBANK_SAMPLE_RATE=24000
TTS_TBANK_MIN_SENTENCE_LEN=4
TTS_TBANK_STREAM_CONTEXT_LEN=1

# Direct Gemini (Google API)
# LLM provider: google | xai
LLM_PROVIDER=google
# Optional model routing providers (both must be set to enable routing):
# FAST_LLM_PROVIDER=google|xai
# COMPLEX_LLM_PROVIDER=google|xai
# If either is empty, routing is disabled and the agent uses LLM_PROVIDER only.
FAST_LLM_PROVIDER=
COMPLEX_LLM_PROVIDER=

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3-flash
# Optional: model used if primary Gemini returns transient 5xx before first token
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite-preview
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=512
GEMINI_TOP_P=1
GEMINI_THINKING_LEVEL=minimal
# Gemini rejects HTTP deadlines below 10s. Keep this separate from
# LLM_ATTEMPT_TIMEOUT_SEC while using LiveKit FallbackAdapter.
GEMINI_HTTP_TIMEOUT_SEC=10.0

# xAI Grok (Responses API)
XAI_API_KEY=
XAI_MODEL=grok-4-1-fast-non-reasoning-latest
XAI_TEMPERATURE=0.3
# Optional regional endpoint (Europe): https://eu-west-1.api.x.ai/v1
XAI_BASE_URL=
# Disable function tools by default for xAI (recommended for lower latency/stability).
# Set true only if you explicitly need tool calling on Grok.
XAI_ENABLE_TOOLS=false

# LLM fallback for live voice. Keep the manual first-token timeout path by
# default; LiveKit FallbackAdapter may wait on provider HTTP timeouts before
# switching in telephony calls.
USE_LIVEKIT_FALLBACK_ADAPTER=false
LLM_ATTEMPT_TIMEOUT_SEC=2.5
LLM_MAX_RETRY_PER_LLM=0
LLM_RETRY_INTERVAL_SEC=0.3
LLM_RETRY_ON_CHUNK_SENT=false
FAST_LLM_BACKUP_PROVIDER=google
FAST_LLM_BACKUP_MODEL=gemini-3.1-flash-lite-preview
COMPLEX_LLM_BACKUP_PROVIDER=google
COMPLEX_LLM_BACKUP_MODEL=gemini-3.1-flash-lite-preview
# Manual fallback knobs used when USE_LIVEKIT_FALLBACK_ADAPTER=false.
LLM_FIRST_TOKEN_TIMEOUT_SEC=2.5
LLM_RETRY_DELAY_SEC=0.3

# Prerecorded voice prompts. Relative paths resolve under agents/main-bot/audio.
# response_delay plays after user speech if the assistant stays silent too long.
VOICE_RESPONSE_DELAY_AUDIO_PATH=response_delay.wav
VOICE_RESPONSE_DELAY_AUDIO_PATHS=response_delay_khmmm.wav,response_delay_emm.wav,response_delay_nuuu.wav,response_delay_khe_khe.wav
VOICE_RESPONSE_DELAY_PHRASE=Секундочку.
VOICE_RESPONSE_DELAY_SEC=3.0
VOICE_RESPONSE_DELAY_POST_GAP_SEC=0.0
# client_silence plays when the assistant is waiting and the client stays silent.
VOICE_CLIENT_SILENCE_AUDIO_PATH=client_silence.wav
VOICE_CLIENT_SILENCE_PHRASE=Алло.
VOICE_CLIENT_SILENCE_SEC=8.0
# emergency plays on unrecoverable runtime errors.
VOICE_EMERGENCY_AUDIO_PATH=emergency.wav
VOICE_EMERGENCY_PHRASE=Извините, перезвоните ещё раз.
# Legacy aliases retained for older env files; prefer VOICE_RESPONSE_DELAY_*.
VOICE_FILLER_AUDIO_PATH=
VOICE_FILLER_PHRASE=Секундочку.

# Endpointing delays (seconds). Lower values reduce "silence before reply".
TURN_MIN_ENDPOINTING_DELAY=0.25
TURN_MAX_ENDPOINTING_DELAY=1.0
# Turn handling mode:
# - vad (Silero VAD — recommended for Google STT, robust multi-turn)
# - stt (STT-based endpointing — only reliable with AssemblyAI; breaks multi-turn with Google STT)
# - multilingual (LiveKit EOU model — best accuracy but requires PyTorch)
TURN_DETECTION_MODE=vad
# Endpointing mode: fixed | dynamic
TURN_ENDPOINTING_MODE=dynamic
# Preemptive generation can reduce latency but may stall on some provider combos.
PREEMPTIVE_GENERATION=true
# If no assistant reply appears after final user turn, force one retry.
# Set 0 to disable.
REPLY_WATCHDOG_SEC=9.0
# Optional universal STT latency guard. When enabled with VAD turn detection,
# the latest interim transcript is emitted as a synthetic final transcript if
# the real STT final flag has not arrived after END_OF_SPEECH.
STT_EARLY_INTERIM_FINAL_ENABLED=false
STT_EARLY_INTERIM_FINAL_DELAY_SEC=0.15

# STT provider:
# - deepgram: Deepgram plugin STT (default, requires DEEPGRAM_API_KEY)
# - inference: LiveKit Agent Gateway STT
# - google: Google Cloud STT
# - yandex: Yandex SpeechKit STT direct gRPC
# - tbank: T-Bank VoiceKit STT direct gRPC StreamingRecognize
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
STT_DEEPGRAM_MODEL=nova-3
STT_DEEPGRAM_LANGUAGE=ru
STT_INFERENCE_MODEL=deepgram/nova-3
# Optional fallback model if primary inference STT is rate-limited (429).
STT_INFERENCE_FALLBACK_MODEL=
STT_INFERENCE_LANGUAGE=ru
# When true, inference STT chain automatically appends Google STT as fallback
# (if Google credentials are available).
STT_INFERENCE_INCLUDE_GOOGLE_FALLBACK=true
STT_GOOGLE_MODEL=latest_long
STT_GOOGLE_LANGUAGE=ru-RU
STT_GOOGLE_LOCATION=global
YANDEX_SPEECHKIT_API_KEY=
STT_YANDEX_MODEL=general
STT_YANDEX_LANGUAGE=ru-RU
STT_YANDEX_SAMPLE_RATE=16000
STT_YANDEX_CHUNK_MS=50
STT_YANDEX_EOU_SENSITIVITY=high
STT_YANDEX_MAX_PAUSE_BETWEEN_WORDS_HINT_MS=500
STT_TBANK_MODEL=
STT_TBANK_LANGUAGE=ru-RU
STT_TBANK_SAMPLE_RATE=16000
STT_TBANK_CHUNK_MS=50
STT_TBANK_INTERIM_INTERVAL_SEC=0.1

# Google Cloud TTS (streaming)
GOOGLE_TTS_MODEL=gemini-3.1-flash-tts-preview
GOOGLE_TTS_FALLBACK_MODEL=gemini-2.5-flash-tts
GOOGLE_TTS_LANGUAGE=ru-RU
GOOGLE_TTS_VOICE_NAME=Zephyr
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0
GOOGLE_TTS_CREDENTIALS_FILE=
# Cloud-friendly alternatives to credentials file:
GOOGLE_TTS_CREDENTIALS_JSON=
GOOGLE_TTS_CREDENTIALS_B64=
GOOGLE_TTS_LOCATION=us-central1
# For Gemini 3.1 keep this enabled.
GOOGLE_TTS_USE_STREAMING=true
# Lower values make streaming start earlier (smaller text chunks).
GOOGLE_TTS_MIN_SENTENCE_LEN=4
GOOGLE_TTS_STREAM_CONTEXT_LEN=1
# Vertex Gemini TTS uses separate buffering controls.
VERTEX_TTS_MIN_SENTENCE_LEN=6
VERTEX_TTS_STREAM_CONTEXT_LEN=2
GOOGLE_TTS_PROMPT=Speak only in Russian. Use pure standard Russian pronunciation with no foreign accent. Sound like a real human receptionist speaking on the phone. Be natural, calm, polite, and professional. Use short, clear, conversational sentences. Keep a medium pace and clear articulation. Use subtle human-like intonation variation. Avoid sounding robotic, theatrical, salesy, or overly cheerful.

# MiniMax TTS
# 1) set TTS_PROVIDER=minimax
# 2) put your API key in MINIMAX_API_KEY
MINIMAX_API_KEY=
MINIMAX_TTS_MODEL=speech-2.8-turbo
MINIMAX_TTS_VOICE_ID=moss_audio_43d3c43e-3a2d-11f1-b47e-928b88df9451
MINIMAX_TTS_BASE_URL=https://api-uw.minimax.io
MINIMAX_TTS_LANGUAGE_BOOST=Russian
MINIMAX_TTS_SPEED=1.0
MINIMAX_TTS_VOLUME=1.0
MINIMAX_TTS_PITCH=-1
# MiniMax voice_modify settings.
MINIMAX_TTS_INTENSITY=15
MINIMAX_TTS_TIMBRE=-5
MINIMAX_TTS_SOUND_EFFECTS=spacious_echo
# MiniMax streaming output format (mp3 recommended).
MINIMAX_TTS_FORMAT=mp3
MINIMAX_TTS_SAMPLE_RATE=24000
MINIMAX_TTS_BITRATE=128000
MINIMAX_TTS_CHANNEL=1
MINIMAX_TTS_MIN_SENTENCE_LEN=4
MINIMAX_TTS_STREAM_CONTEXT_LEN=1

# CosyVoice TTS (Alibaba Cloud Model Studio WebSocket streaming)
# 1) set TTS_PROVIDER=cosyvoice
# 2) set COSYVOICE_API_KEY (or custom env var name via COSYVOICE_API_KEY_ENV_NAME)
# 3) set one of voice ids based on voice mode
# Note: cosyvoice-v3.5-* models typically require clone/design voice ids.
COSYVOICE_PROFILE=cosyvoice_cn_flash_fast
COSYVOICE_API_KEY_ENV_NAME=COSYVOICE_API_KEY
COSYVOICE_API_KEY=
COSYVOICE_TTS_TRANSPORT=websocket
COSYVOICE_TTS_REGION=cn-beijing
COSYVOICE_TTS_WS_URL=
COSYVOICE_TTS_MODEL=cosyvoice-v3.5-flash
COSYVOICE_TTS_VOICE_MODE=preset
COSYVOICE_TTS_VOICE_ID=
COSYVOICE_TTS_CLONE_VOICE_ID=
COSYVOICE_TTS_DESIGN_VOICE_ID=
COSYVOICE_TTS_FORMAT=pcm
COSYVOICE_TTS_SAMPLE_RATE=24000
COSYVOICE_TTS_RATE=1.0
COSYVOICE_TTS_PITCH=1.0
COSYVOICE_TTS_VOLUME=50
COSYVOICE_TTS_CONNECTION_REUSE=true
COSYVOICE_TTS_PLAYBACK_ON_FIRST_CHUNK=true
COSYVOICE_TTS_MIN_SENTENCE_LEN=4
COSYVOICE_TTS_STREAM_CONTEXT_LEN=1
# Quality comparison profile:
# COSYVOICE_PROFILE=cosyvoice_cn_plus_quality
# COSYVOICE_TTS_MODEL=cosyvoice-v3.5-plus

# Optional: prompt lookup by LiveKit SIP trunk phone number through Directus.
# Use a read-only Directus role named "Livekit"; do not use an admin token here.
DIRECTUS_URL=
DIRECTUS_TOKEN=
DIRECTUS_REQUEST_TIMEOUT_SEC=2.0
DIRECTUS_PROMPT_CACHE_TTL_SEC=300
DIRECTUS_DEFAULT_TIMEZONE=Europe/Kaliningrad
DIRECTUS_COLLECTION_CALLER_ID=CallerID
DIRECTUS_COLLECTION_BOT_CONFIGURATIONS=bot_configurations
DIRECTUS_COLLECTION_CLIENTS=clients
DIRECTUS_COLLECTION_CLIENTS_PROMPT=clients_prompt
DIRECTUS_COLLECTION_WEBPARSING=webparsing
DIRECTUS_COLLECTION_TRANSFER_NUMBER=transfer_number
DIRECTUS_COLLECTION_CLIENT_PROMPT_CACHE=client_prompt_cache

# Legacy Postgres prompt lookup settings. Kept for older env files, but the
# runtime prompt resolver now uses Directus and falls back to src/prompt.txt.
POSTGRES_DSN=
PROMPT_LOOKUP_SQL=
PROMPT_LOOKUP_TIMEOUT_SEC=2.0

# Optional: export session data to n8n
N8N_WEBHOOK_URL=
N8N_WEBHOOK_TOKEN=

# SMS_LINK skill. Keep real values in .env.local or LiveKit Cloud secrets.
SMS_RU_API_URL=https://sms.ru/sms/send
SMS_RU_API_ID=
SMS_LINK_SIGNATURE=Отправил наш ИИ робот: jcall.io
