# Bootstrap: runtime identity and LiveKit connection.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
AGENT_NAME=main-bot
ROBOT_RUNTIME_PROFILE=base
ROBOT_SETTINGS_USE_DIRECTUS=true
ROBOT_SETTINGS_CACHE_TTL_SEC=300
ROBOT_SETTINGS_SNAPSHOT_FILE=config/robot_settings_snapshot.json

# Directus is the source of truth for robot LLM/TTS/STT/Turn profiles.
# Use a service token with read access to robot settings and prompt collections.
DIRECTUS_URL=
DIRECTUS_TOKEN=
DIRECTUS_REQUEST_TIMEOUT_SEC=2.0
DIRECTUS_PROMPT_CACHE_TTL_SEC=300
DIRECTUS_DEFAULT_TIMEZONE=Europe/Kaliningrad
DIRECTUS_COLLECTION_CALLER_ID=CallerID
DIRECTUS_COLLECTION_BOT_CONFIGURATIONS=bot_configurations
DIRECTUS_COLLECTION_CLIENTS=clients
DIRECTUS_COLLECTION_CLIENTS_PROMPT=clients_prompt
DIRECTUS_COLLECTION_WEBPARSING=webparsing
DIRECTUS_COLLECTION_TRANSFER_NUMBER=transfer_number
DIRECTUS_COLLECTION_CLIENT_PROMPT_CACHE=client_prompt_cache
DIRECTUS_INITIAL_GREETING_FIELD=first_step

# Provider credentials stay in env / LiveKit Cloud secrets.
# Directus profiles should reference these names through *_ref fields.
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVEN_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPGRAM_API_KEY=
YANDEX_SPEECHKIT_API_KEY=
MINIMAX_API_KEY=
COSYVOICE_API_KEY=
TBANK_VOICEKIT_API_KEY=
TBANK_VOICEKIT_SECRET_KEY=
VOICEKIT_API_KEY=
VOICEKIT_SECRET_KEY=
SBER_SALUTESPEECH_AUTH_KEY=
SBER_AUTH_KEY=
GOOGLE_TTS_CREDENTIALS_FILE=
GOOGLE_TTS_CREDENTIALS_JSON=
GOOGLE_TTS_CREDENTIALS_B64=

# Provider egress routing.
# direct: connect from the LiveKit worker directly.
# proxy: connect through the VPS Squid HTTP CONNECT proxy in EGRESS_PROXY_URL.
# Do not set global HTTPS_PROXY for the agent; use per-provider egress instead.
EGRESS_PROXY_URL=http://66.248.207.203:15182
EGRESS_DEFAULT=direct
ELEVENLABS_EGRESS=proxy
GEMINI_EGRESS=proxy
GOOGLE_TTS_EGRESS=proxy
VERTEX_TTS_EGRESS=proxy
GOOGLE_STT_EGRESS=proxy
TBANK_VOICEKIT_EGRESS=direct
XAI_EGRESS=direct
DEEPGRAM_EGRESS=direct
MINIMAX_TTS_EGRESS=direct
COSYVOICE_TTS_EGRESS=direct
SBER_TTS_EGRESS=direct
LIVEKIT_INFERENCE_EGRESS=proxy

# T-Bank VoiceKit infrastructure. Voice/model tuning belongs to Directus.
TBANK_VOICEKIT_ENDPOINT=api.tinkoff.ai:443
TBANK_VOICEKIT_AUTHORITY=

# Agent process and health endpoints.
LIVEKIT_SELF_HOSTED=false
AGENT_HEALTH_HOST=
AGENT_HEALTH_PORT=8081
AGENT_MAX_CONCURRENT_JOBS=1
AGENT_NUM_IDLE_PROCESSES=0
AUDIO_INPUT_ENHANCEMENT=none

# Prerecorded voice prompts and local audio cache are process-level safety knobs.
VOICE_AUDIO_CACHE_ENABLED=true
VOICE_AUDIO_CACHE_DIR=cache
VOICE_AUDIO_LEGACY_PROFILE_ID=
VOICE_INITIAL_GREETING_PHRASE=Здравствуйте! Это компания Кофемастер! Чем могу помочь?
VOICE_SHORT_GREETING_PHRASE=Здравствуйте, я виртуальный ассистент. Подскажите, чем могу вам помочь?
VOICE_RESPONSE_DELAY_AUDIO_PATH=response_delay.wav
VOICE_RESPONSE_DELAY_AUDIO_PATHS=response_delay_khmmm.wav,response_delay_emm.wav,response_delay_nuuu.wav,response_delay_khe_khe.wav
VOICE_RESPONSE_DELAY_PHRASE=Секундочку.
VOICE_RESPONSE_DELAY_SEC=3.0
VOICE_RESPONSE_DELAY_POST_GAP_SEC=0.0
VOICE_CLIENT_SILENCE_AUDIO_PATH=client_silence.wav
VOICE_CLIENT_SILENCE_PHRASE=Алло.
VOICE_CLIENT_SILENCE_SEC=8.0
VOICE_EMERGENCY_AUDIO_PATH=emergency.wav
VOICE_EMERGENCY_PHRASE=Извините, перезвоните ещё раз.
REPLY_WATCHDOG_SEC=9.0

# Session export and webhooks.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_TOKEN=

# SMS_LINK skill. Keep real values in .env.local or LiveKit Cloud secrets.
SMS_RU_API_URL=https://sms.ru/sms/send
SMS_RU_API_ID=
SMS_LINK_SIGNATURE=Отправил наш ИИ робот: jcall.io

# Robot incident diagnostics.
# Production path is Directus API over HTTPS. Direct Postgres is dev/fallback only.
INCIDENT_LOG_ENABLED=true
INCIDENT_LOG_TRANSPORT=directus
INCIDENT_DIRECTUS_URL=
INCIDENT_DIRECTUS_TOKEN=
INCIDENT_POSTGRES_DSN=
INCIDENT_ENVIRONMENT=cloud
INCIDENT_DB_TIMEOUT_SEC=1.5
INCIDENT_SLOW_RESPONSE_MS=7000

# Legacy Postgres prompt lookup settings. Prefer Directus prompt lookup.
# POSTGRES_DSN=
# PROMPT_LOOKUP_SQL=
# PROMPT_LOOKUP_TIMEOUT_SEC=2.0

