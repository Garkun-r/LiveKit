# Mac development profile.
# Use this for local console/dev runs from this repository checkout.

DEPLOYMENT_PROFILE=mac
AGENT_NAME=main-bot-mac
INCIDENT_ENVIRONMENT=mac

# Fill these from the LiveKit project you want the Mac agent to connect to.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Mac is a dev process, not the self-hosted Asterisk production worker.
LIVEKIT_SELF_HOSTED=false
AGENT_HEALTH_HOST=
AGENT_HEALTH_PORT=8081
AGENT_MAX_CONCURRENT_JOBS=2
AGENT_NUM_IDLE_PROCESSES=1
AUDIO_INPUT_ENHANCEMENT=none

# Default to direct egress on the Mac. Override individual providers only when
# you are deliberately testing the Asterisk/VPS proxy path.
EGRESS_PROXY_URL=
EGRESS_DEFAULT=direct
ELEVENLABS_EGRESS=direct
GEMINI_EGRESS=direct
GOOGLE_TTS_EGRESS=direct
VERTEX_TTS_EGRESS=direct
GOOGLE_STT_EGRESS=direct
XAI_EGRESS=direct
DEEPGRAM_EGRESS=direct
MINIMAX_TTS_EGRESS=direct
COSYVOICE_TTS_EGRESS=direct
LIVEKIT_INFERENCE_EGRESS=direct
