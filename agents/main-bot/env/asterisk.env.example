# Asterisk/self-hosted LiveKit profile.
# The current production file on the server is:
# /etc/jcall-livekit-agent/main-bot.env
# Treat that server file as source of truth until you intentionally migrate it.

DEPLOYMENT_PROFILE=asterisk
AGENT_NAME=main-bot-asterisk
INCIDENT_ENVIRONMENT=asterisk

# Fill from the local LiveKit server. Do not commit real values.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

LIVEKIT_SELF_HOSTED=true
AGENT_HEALTH_HOST=127.0.0.1
AGENT_HEALTH_PORT=18081
AGENT_MAX_CONCURRENT_JOBS=10
AGENT_NUM_IDLE_PROCESSES=1
AUDIO_INPUT_ENHANCEMENT=none

# Measured production egress route for the Asterisk/local LiveKit server.
EGRESS_PROXY_URL=http://66.248.207.203:15182
EGRESS_DEFAULT=direct
ELEVENLABS_EGRESS=proxy
GEMINI_EGRESS=proxy
GOOGLE_TTS_EGRESS=proxy
VERTEX_TTS_EGRESS=proxy
GOOGLE_STT_EGRESS=proxy
XAI_EGRESS=direct
DEEPGRAM_EGRESS=direct
MINIMAX_TTS_EGRESS=direct
COSYVOICE_TTS_EGRESS=direct
LIVEKIT_INFERENCE_EGRESS=proxy

# Important: changing AGENT_NAME requires updating the SIP dispatch rule to
# target the same name. Keep the current server env unchanged until that is done.
