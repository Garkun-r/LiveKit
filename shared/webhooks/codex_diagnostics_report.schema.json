{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "findings", "recommendations", "telegram_brief", "markdown"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["ok", "watch", "needs_attention", "critical"]
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "severity",
          "stage",
          "event_time_or_turn",
          "exact_detail",
          "evidence",
          "why_it_matters",
          "confidence",
          "suspected_cause",
          "recommendation",
          "implementation_idea",
          "missing_evidence"
        ],
        "properties": {
          "title": {"type": "string"},
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "error", "critical"]
          },
          "stage": {"type": "string"},
          "event_time_or_turn": {"type": "string"},
          "exact_detail": {"type": "string"},
          "evidence": {"type": "string"},
          "why_it_matters": {"type": "string"},
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "suspected_cause": {"type": "string"},
          "recommendation": {"type": "string"},
          "implementation_idea": {"type": "string"},
          "missing_evidence": {"type": "string"}
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "telegram_brief": {
      "type": "string"
    },
    "markdown": {
      "type": "string"
    }
  }
}
